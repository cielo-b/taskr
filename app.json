{
  "expo": {
    "name": "taskr",
    "slug": "taskr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "taskr",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E293B"
    },
    "ios": {
      "supportsTablet": true,
      "statusBarStyle": "light"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E293B"
      },
      "edgeToEdgeEnabled": true,
      "navigationBar": {
        "visible": "immersive",
        "backgroundColor": "#1E293B"
      },
      "statusBar": {
        "barStyle": "light-content",
        "backgroundColor": "#1E293B",
        "translucent": true
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-navigation-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
